# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Database ─────────────────────────────────────────────────────────────────
# Get from Supabase: Settings → Database → Connection string (URI)
# Use the "Session mode" connection string (port 5432)
# For Prisma 7, this goes in prisma.config.ts via env("DATABASE_URL")
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Get from https://resend.com — create an API key
# Also verify your sending domain in Resend dashboard
RESEND_API_KEY=re_xxxxxxxxxxxx

# ─── Cron Security ───────────────────────────────────────────────────────────
# A random secret string to protect the /api/cron/sync-il endpoint
# Vercel Cron will send this as the "x-cron-secret" header
CRON_SECRET=your-random-secret-here

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
